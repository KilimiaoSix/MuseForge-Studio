{
  "name": "sd-agent-studio",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "sd-agent-studio",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/backend": {
      "name": "@sd-agent-studio/backend",
      "version": "0.1.0",
      "dependencies": {
        "@sd-agent-studio/model-providers": "0.1.0",
        "@sd-agent-studio/shared": "0.1.0"
      }
    },
    "apps/ui-prototype": {
      "name": "@sd-agent-studio/ui-prototype",
      "version": "0.1.0"
    },
    "node_modules/@sd-agent-studio/backend": {
      "resolved": "apps/backend",
      "link": true
    },
    "node_modules/@sd-agent-studio/model-providers": {
      "resolved": "packages/model-providers",
      "link": true
    },
    "node_modules/@sd-agent-studio/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@sd-agent-studio/ui-prototype": {
      "resolved": "apps/ui-prototype",
      "link": true
    },
    "packages/model-providers": {
      "name": "@sd-agent-studio/model-providers",
      "version": "0.1.0",
      "dependencies": {
        "@sd-agent-studio/shared": "0.1.0"
      }
    },
    "packages/shared": {
      "name": "@sd-agent-studio/shared",
      "version": "0.1.0"
    }
  }
}
