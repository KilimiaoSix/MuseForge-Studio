# Backend
SD_AGENT_HOST=127.0.0.1
SD_AGENT_PORT=8787

# A1111 inference backend
A1111_BASE_URL=http://127.0.0.1:7860
SD_WEBUI_BASE_URL=http://127.0.0.1:7860
# macOS Apple Silicon / MPS compatibility: allows unsupported MPS ops to fall back to CPU.
PYTORCH_ENABLE_MPS_FALLBACK=1
# Optional: point MuseForge at an existing local A1111 folder instead of vendor/engines/stable-diffusion-webui.
SD_WEBUI_ROOT=
A1111_REPO_URL=https://github.com/AUTOMATIC1111/stable-diffusion-webui.git
ENGINE_INSTALL_DIR=vendor/engines

# Default model provider for Agent planning.
# Web-configured provider profiles in local SQLite take priority over these values.
AGENT_PROVIDER=local
AGENT_MODEL=gemma4:e4b
AGENT_BASE_URL=http://127.0.0.1:11434/v1
AGENT_API_KEY=

# Optional OpenAI provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Optional Gemini provider
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-2.5-flash

# Optional Anthropic / Claude-like provider
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Optional cloud creative engine provider.
# Use for Jimeng-like image/video platforms or custom API adapters.
CREATIVE_ENGINE_PROVIDER=
CREATIVE_ENGINE_BASE_URL=
CREATIVE_ENGINE_MODEL=
CREATIVE_ENGINE_API_KEY=
JIMENG_API_KEY=
JIMENG_BASE_URL=
JIMENG_MODEL=

# Optional LoRA trainer integration
KOHYA_SS_PATH=
SD_SCRIPTS_PATH=
