# Backend
SD_AGENT_HOST=127.0.0.1
SD_AGENT_PORT=8787

# Inference engines
INFERENCE_BACKEND=comfyui
COMFYUI_BASE_URL=http://127.0.0.1:8188
A1111_BASE_URL=http://127.0.0.1:7860
SD_WEBUI_BASE_URL=http://127.0.0.1:7860
COMFYUI_REPO_URL=https://github.com/comfyanonymous/ComfyUI.git
A1111_REPO_URL=https://github.com/AUTOMATIC1111/stable-diffusion-webui.git
ENGINE_INSTALL_DIR=vendor/engines
PYTHON_EXE=python
COMFYUI_TIMEOUT_MS=300000

# Default model provider for Agent planning
AGENT_PROVIDER=openai-compatible
AGENT_MODEL=qwen2.5-7b-instruct
AGENT_BASE_URL=http://127.0.0.1:1234/v1
AGENT_API_KEY=

# Optional OpenAI provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Optional Anthropic / Claude-like provider
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Optional LoRA trainer integration
KOHYA_SS_PATH=
SD_SCRIPTS_PATH=
